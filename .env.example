# CranL PostgreSQL. Server-only; never expose through VITE_*.
DATABASE_URL=

# Set to true only when the managed database requires TLS without local CA validation.
DATABASE_SSL=false

# ---------------------------------------------------------------------------
# Server-only secrets
# ---------------------------------------------------------------------------
# Embeddings provider key. Lives only on the server.
# Model: OpenAI text-embedding-3-small (1536 dims) — must match vector(1536) in the migration.
OPENAI_API_KEY=
