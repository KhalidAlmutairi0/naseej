# Client (browser-safe, injected by Vite as VITE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Edge function secrets (set via `supabase secrets set` — NEVER exposed to the client)
# ---------------------------------------------------------------------------
# Service role key: used by verify-otp (creates auth.users + customers) and
# shop registration to bypass RLS in a controlled server context.
SUPABASE_SERVICE_ROLE_KEY=

# Embeddings provider key. Lives ONLY inside embed-fabric and semantic-search.
# Model: OpenAI text-embedding-3-small (1536 dims) — must match vector(1536) in the migration.
OPENAI_API_KEY=
