# Supabase browser-safe values from Project Settings -> API.
VITE_SUPABASE_URL=
# Use either the legacy anon key name or Supabase's newer publishable key name.
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Server-only secrets
# ---------------------------------------------------------------------------
# Supabase service role key. Never expose through VITE_*.
SUPABASE_SERVICE_ROLE_KEY=

# Embeddings provider key. Lives only on the server.
# Model: OpenAI text-embedding-3-small (1536 dims) — must match vector(1536) in the migration.
OPENAI_API_KEY=
